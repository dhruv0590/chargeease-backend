# ─────────────────────────────────────────
#  ChargEase API – Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# PostgreSQL connection string (from Railway dashboard)
DATABASE_URL=postgresql://postgres:yourpassword@hostname.railway.app:5432/railway

# JWT secret – use a long random string in production
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_string

# Port (Railway sets this automatically; 4000 for local dev)
PORT=4000

# Frontend origin for CORS (your Vercel URL or localhost for dev)
CLIENT_ORIGIN=http://localhost:3000
